# RSA Algorithm Implementation in Python (without external packages)

p = 3
q = 11

n = p * q
phi = (p - 1) * (q - 1)

e = 3

# find d
for i in range(1, phi):
    if (e * i) % phi == 1:
        d = i
        break

print("Public Key (e,n):", (e, n))
print("Private Key (d,n):", (d, n))

msg = 7

# Encryption
c = (msg ** e) % n
print("Encrypted message:", c)

# Decryption
m = (c ** d) % n
print("Decrypted message:", m)
